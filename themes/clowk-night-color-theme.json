  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#fbbf24",
    "interface": "#22d3ee",
    "type": "#22d3ee",
    "typeParameter": { "foreground": "#22d3ee", "fontStyle": "italic" },
    "enum": "#fbbf24",
    "enumMember": "#e0a5c5",
    "function": "#a78bfa",
