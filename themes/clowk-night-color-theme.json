    "method": "#a78bfa",
    "method.declaration": "#a78bfa",
    "macro": "#e0a5c5",
    "variable": "#e0def4",
    "variable.readonly": "#e0def4",
    "variable.declaration": "#e0def4",
    "parameter": { "foreground": "#e0def4", "fontStyle": "italic" },
    "property": "#e0def4",
    "property.declaration": "#e0def4",
    "namespace": "#7aafe0",
    "keyword": "#c2a6e2",
