    "dropdown.background": "#0c0b14",
    "dropdown.foreground": "#e0def4",
    "dropdown.border": "#2a2740",
    "dropdown.listBackground": "#0c0b14",

    "button.background": "#7c3aed",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#6d28d9",
    "button.secondaryBackground": "#2a2740",
    "button.secondaryForeground": "#e0def4",
    "button.secondaryHoverBackground": "#393552",

    "checkbox.background": "#0c0b14",
    "checkbox.border": "#2a2740",
    "checkbox.foreground": "#e0def4",

    "badge.background": "#7c3aed",
    "badge.foreground": "#ffffff",

    "scrollbar.shadow": "#00000033",
    "scrollbarSlider.background": "#2a274088",
    "scrollbarSlider.hoverBackground": "#7c3aed55",
    "scrollbarSlider.activeBackground": "#7c3aed88",

    "progressBar.background": "#7c3aed",

    "breadcrumb.foreground": "#6e6a86",
    "breadcrumb.focusForeground": "#e0def4",
    "breadcrumb.activeSelectionForeground": "#c2a6e2",
    "breadcrumbPicker.background": "#0c0b14",

    "notifications.background": "#0c0b14",
    "notifications.foreground": "#e0def4",
    "notifications.border": "#1e1b3a",
    "notificationToast.border": "#7c3aed88",
    "notificationsInfoIcon.foreground": "#22d3ee",
    "notificationsWarningIcon.foreground": "#fbbf24",
    "notificationsErrorIcon.foreground": "#f87171",

    "commandCenter.background": "#0c0b14",
    "commandCenter.foreground": "#908caa",
    "commandCenter.border": "#2a2740",
    "commandCenter.activeBackground": "#161425",
    "commandCenter.activeForeground": "#e0def4",
    "commandCenter.activeBorder": "#7c3aed88",

    "quickInput.background": "#0c0b14",
    "quickInput.foreground": "#e0def4",
    "quickInputList.focusBackground": "#7c3aed33",
    "quickInputList.focusForeground": "#e0def4",

    "peekView.border": "#7c3aed",
    "peekViewEditor.background": "#0c0b14",
    "peekViewEditor.matchHighlightBackground": "#7c3aed44",
    "peekViewResult.background": "#0a0914",
    "peekViewResult.fileForeground": "#e0def4",
    "peekViewResult.lineForeground": "#908caa",
    "peekViewResult.matchHighlightBackground": "#7c3aed44",
    "peekViewResult.selectionBackground": "#7c3aed33",
    "peekViewResult.selectionForeground": "#e0def4",
    "peekViewTitle.background": "#0a0914",
    "peekViewTitleDescription.foreground": "#908caa",
    "peekViewTitleLabel.foreground": "#e0def4",

    "merge.currentHeaderBackground": "#6ec89e44",
    "merge.currentContentBackground": "#6ec89e22",
    "merge.incomingHeaderBackground": "#7aafe044",
    "merge.incomingContentBackground": "#7aafe022",

    "diffEditor.insertedTextBackground": "#6ec89e15",
    "diffEditor.removedTextBackground": "#f8717115",
    "diffEditor.insertedLineBackground": "#6ec89e0d",
    "diffEditor.removedLineBackground": "#f871710d",

    "gitDecoration.addedResourceForeground": "#6ec89e",
    "gitDecoration.modifiedResourceForeground": "#fbbf24",
    "gitDecoration.deletedResourceForeground": "#f87171",
    "gitDecoration.untrackedResourceForeground": "#22d3ee",
    "gitDecoration.conflictingResourceForeground": "#e0a5c5",
    "gitDecoration.ignoredResourceForeground": "#4a4662",
    "gitDecoration.renamedResourceForeground": "#a78bfa",
    "gitDecoration.stageModifiedResourceForeground": "#fbbf24",

    "debugToolBar.background": "#0c0b14",
    "debugIcon.breakpointForeground": "#f87171",
    "debugIcon.startForeground": "#6ec89e",
    "debugIcon.pauseForeground": "#fbbf24",
    "debugIcon.stopForeground": "#f87171",
    "debugConsole.infoForeground": "#22d3ee",
    "debugConsole.warningForeground": "#fbbf24",
    "debugConsole.errorForeground": "#f87171",

    "settings.headerForeground": "#e0def4",
    "settings.modifiedItemIndicator": "#7c3aed",
    "settings.focusedRowBackground": "#7c3aed11",

    "welcomePage.tileBackground": "#0c0b14",
    "welcomePage.tileBorder": "#1e1b3a",
    "walkThrough.embeddedEditorBackground": "#0c0b14"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.block",
        "comment.line",
        "comment.block.documentation",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4a4680",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple"
      ],
      "settings": {
        "foreground": "#6ec89e"
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#c2a6e2"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "punctuation.definition.character-class.regexp"
      ],
      "settings": {
        "foreground": "#e0a5c5"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.decimal",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "Boolean & Null constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#e0a5c5"
      }
    },
    {
      "name": "Other constants",
      "scope": [
        "constant.other",
        "constant.character"
      ],
      "settings": {
        "foreground": "#e0a5c5"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.trycatch",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#c2a6e2"
      }
    },
    {
      "name": "Import/Export keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.default"
      ],
      "settings": {
        "foreground": "#c2a6e2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Return, yield, await",
      "scope": [
        "keyword.control.return",
        "keyword.control.yield",
        "keyword.control.await"
      ],
      "settings": {
        "foreground": "#c2a6e2"
      }
    },
    {
      "name": "Storage types (fn, let, const, struct, enum, impl)",
      "scope": [
        "storage.type"
      ],
      "settings": {
        "foreground": "#c2a6e2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage modifiers (pub, mut, static, async)",
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7aafe0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.assignment",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest"
      ],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "name": "Arrow function operator",
      "scope": [
        "keyword.operator.arrow",
        "storage.type.function.arrow"
      ],
      "settings": {
        "foreground": "#c2a6e2"
      }
    },
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "name": "Function calls & support functions",
      "scope": [
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "name": "Method calls",
      "scope": [
        "meta.method-call entity.name.function",
        "entity.name.function.member"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function variable.parameter"
      ],
      "settings": {
        "foreground": "#e0def4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#e0def4"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#e0def4"
      }
    },
    {
      "name": "this, self, super",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#e0a5c5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Class names",
      "scope": [
        "entity.name.type.class",
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "Inherited class",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type names & interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.type.interface",
        "entity.name.type.alias",
        "entity.name.type.enum",
        "support.type"
      ],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "name": "Type parameters (generics)",
      "scope": [
        "entity.name.type.parameter"
      ],
      "settings": {
        "foreground": "#22d3ee",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML/JSX tags",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#f87171"
      }
    },
    {
      "name": "HTML/JSX attribute names",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML attribute values (URLs, IDs)",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#6ec89e"
      }
    },
    {
      "name": "CSS property names",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#7aafe0"
      }
    },
    {
      "name": "CSS property values",
      "scope": [
        "support.constant.property-value.css",
        "constant.numeric.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#6ec89e"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "CSS pseudo selectors",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "name": "SCSS/SASS variables",
      "scope": [
        "variable.scss",
        "variable.sass"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "name": "Escape characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#6e6a86"
      }
    },
    {
      "name": "Tag punctuation (< > /)",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#6e6a86"
      }
    },
    {
      "name": "JSON property names",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "name": "JSON string values",
      "scope": [
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#6ec89e"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "heading.1.markdown entity.name",
        "heading.2.markdown entity.name",
        "heading.3.markdown entity.name",
        "heading.4.markdown entity.name",
        "heading.5.markdown entity.name",
        "heading.6.markdown entity.name",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#c2a6e2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#e0a5c5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#22d3ee"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#7aafe0"
      }
    },
    {
      "name": "Markdown list markers",
      "scope": [
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "name": "TOML keys",
      "scope": [
        "keyword.key.toml",
        "support.type.property-name.toml"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
